lightThemeColorPalette":{"baseBackground":4293982719,"raisedBackground":4293982719,"additiveBackground":558208969,"textPrimary":4278854966,"textSecondary":4282014318,"invertedBackground":4279853711,"overlayBackground":3423216950},"darkThemeColorPalette":{"baseBackground":4278325788,"raisedBackground":4278854966,"additiveBackground":725981129,"textPrimary":4292931834,"textSecondary":4289514205,"invertedBackground":4286364899,"overlayBackground":3423216950},"colorSampledDescriptionBodyText":{"content":"Statistics and Its Applications in Management 1 | Session 1 | Basic Statistical Concepts\n\n🎓 در این جلسه، «مفاهیم اولیه آمار» را به‌عنوان نقطهٔ شروع درس آمار و کاربرد آن در مدیریت ۱، با بیانی ساده، روان و کاملاً قابل‌فهم بررسی می‌کنیم.  \nاین جلسه برای دانشجویان مدیریت، حسابداری، اقتصاد، علوم اجتماعی و تمامی علاقه‌مندان به تحلیل داده‌ها بسیار مناسب است.  \nاگر می‌خواهید بدانید آمار چیست، چرا در مدیریت اهمیت دارد و چه مفاهیمی پایهٔ تحلیل‌های آماری را تشکیل می‌دهند، این جلسه بهترین نقطهٔ شروع است.\n\n👨‍🏫 تدریس توسط دکتر حمیدرضا یوسف‌زاده، عضو هیئت علمی دانشگاه پیام نور\n\n\n\n📘 در این جلسه چه می‌آموزید؟\nتعریف آمار و نقش آن در مدیریت  \nتفاوت آمار توصیفی و آمار استنباطی  \nجامعه، نمونه و روش‌های نمونه‌گیری  \nانواع داده‌ها و مقیاس‌های سنجش (اسمی، ترتیبی، فاصله‌ای، نسبی)  \nکاربرد آمار در تصمیم‌گیری مدیریتی  \nمثال‌های کاربردی از محیط کسب‌وکار  \nنکات کلیدی امتحانی و اشتباهات رایج دانشجویان  \nآشنایی با Statistics for Management و مفاهیم پایهٔ تحلیل داده  \n\nاین جلسه آغاز مجموعهٔ آموزش کامل درس آمار و کاربرد آن در مدیریت ۱ است و برای آمادگی امتحانات پیام‌نور و سایر دانشگاه‌ها بسیار کاربردی خواهد بود.\n\n\n\n🔗 لینک‌های مرتبط با این درس\n\n🎥 پلی‌لیست آموزش کامل آمار و کاربرد آن در مدیریت ۱:  \n[   • Statistics for Management | آمار و کاربرد ...  ]\n\n\n\n📢 کانال اطلاع‌رسانی تلگرام (تمام لینک‌های دانلود اینجاست):  \n[https://t.me/HRYMATH]\n\n📚 دانلود کتاب و جزوه:  \nدر کانال اطلاع‌رسانی تلگرام قرار دارد.\n\n\n\n🎯 اگر این جلسه برایتان مفید بود، خوشحال می‌شوم نظر و تجربه‌تان را در بخش کامنت‌ها بنویسید.  \nبرای اطلاع از انتشار جلسات جدید و دریافت لینک‌های مرتبط، کانال اطلاع‌رسانی تلگرام را دنبال کنید.\n\n\n\n🔑 کلمات کلیدی\nآمار و کاربرد آن در مدیریت، پیام نور، مفاهیم اولیه آمار، داده‌ها،  \nStatistics for Management, Descriptive Statistics, Sampling, Data Types, Business Analytics\n\n🏷️ هشتگ‌ها\n#آمار_و_کاربرد_آن_در_مدیریت\n#پیام_نور\n#Statistics\n#StatisticsForManagement\n#DataAnalysis","commandRuns":[{"startIndex":1190,"length":52,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBUQ040EGAYiEwjr9um314eUAxWtHrMFHcYeA5LKAQQxt8HE","commandMetadata":{"webCommandMetadata":{"url":"/playlist?list=PLiayeEFSBVbhCy5XwjamrgS9I07IMkl8S","webPageType":"WEB_PAGE_TYPE_PLAYLIST","rootVe":5754,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"VLPLiayeEFSBVbhCy5XwjamrgS9I07IMkl8S","canonicalBaseUrl":"/playlist?list=PLiayeEFSBVbhCy5XwjamrgS9I07IMkl8S"}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"YouTube Channel Link: Statistics for Management | آمار و کاربرد آن در مدیریت ۱"}}},{"startIndex":1310,"length":20,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBUQ040EGAYiEwjr9um314eUAxWtHrMFHcYeA5JIs5Dz-oHlmqHsAcoBBDG3wcQ=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFVIYUtzNE1Ic3lXNkg1dUVvdmZlRjhvQzBMQXxBQ3Jtc0ttNVlBSGRLR1FpRXVqYS16WWV2ZFMtYnJIeEdSYnlZVV9qekFMLXdDTlZrZ0VGekJ0eGdNdHpZQ05pdmJVR3VuZV9FODRzdVllVHRVbzVPTG5LejNTdHFpcS0wLWxIa3YzMExDZndPeGZ3bFJoQUJPNA\u0026q=https%3A%2F%2Ft.me%2FHRYMATH\u0026v=7EJrKB9cyDM","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFVIYUtzNE1Ic3lXNkg1dUVvdmZlRjhvQzBMQXxBQ3Jtc0ttNVlBSGRLR1FpRXVqYS16WWV2ZFMtYnJIeEdSYnlZVV9qekFMLXdDTlZrZ0VGekJ0eGdNdHpZQ05pdmJVR3VuZV9FODRzdVllVHRVbzVPTG5LejNTdHFpcS0wLWxIa3YzMExDZndPeGZ3bFJoQUJPNA\u0026q=https%3A%2F%2Ft.me%2FHRYMATH\u0026v=7EJrKB9cyDM","target":"TARGE